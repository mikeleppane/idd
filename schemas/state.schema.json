{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/state.schema.json",
  "title": "FORGE Per-Feature State",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature_id", "tier", "current_phase", "phases", "skipped", "deviations", "commits"],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])-[a-z0-9](?:[a-z0-9]|-(?=[a-z0-9]))+$",
      "description": "YYYY-MM-DD-slug identifier."
    },
    "tier": {
      "type": "string",
      "enum": ["focused", "standard", "full"]
    },
    "current_phase": {
      "type": "string",
      "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa", "done"]
    },
    "flow_version": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "State machine generation. 1 = pre-collapse 9-step standard tier; 2 = collapsed 5-step standard; 3 = adds qa as a terminal post-ship phase. Absence of this field means v1 by convention; application code treats missing field as v1."
    },
    "phases": {
      "type": "object",
      "propertyNames": {
        "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa"]
      },
      "properties": {
        "review": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "in_progress", "done", "skipped"]
            },
            "started_at":   { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "current_target": {
              "type": "string",
              "enum": ["plan", "code"]
            },
            "targets_done": {
              "type": "array",
              "items": { "type": "string", "enum": ["plan", "code"] },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "research": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "done", "skipped"] },
            "started_at":   { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "current_slice": { "type": "integer", "minimum": 1 },
            "parallel_used": {
              "type": "boolean",
              "default": false,
              "description": "Reserved for M8 P2 intel-aware multi-agent escalation; P0 ships single-agent only. Absence implies false. Locking the field shape now keeps the M8 P2 consumer from forcing a schema bump on day one."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "skipped"]
          },
          "started_at":   { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "current_slice": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "reason"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "cause", "resolution"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa"]
          },
          "cause":      { "type": "string" },
          "resolution": { "type": "string" },
          "logged_at":  { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sha", "phase", "subject"],
        "properties": {
          "sha":     { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa"]
          },
          "subject": { "type": "string", "minLength": 1 },
          "logged_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idea", "final_tier", "decided_at"],
      "properties": {
        "idea": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "proposed_tier": { "type": "string", "enum": ["focused", "standard", "full"] },
        "final_tier": { "type": "string", "enum": ["focused", "standard", "full"] },
        "rationale": { "type": "string" },
        "constitution_present": { "type": "boolean" },
        "decided_at": { "type": "string", "format": "date-time" },
        "refine_attempts": { "type": "integer", "minimum": 0, "maximum": 5 },
        "phase_list": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "qa"]
          },
          "uniqueItems": true,
          "minItems": 1,
          "description": "Ordered list of phases this feature will execute. Set by /forge:do at routing time. Lazy-derived for legacy features lacking the field. Order-sensitive (consumed positionally by next_phase_command); review never repeats (uniqueItems)."
        }
      }
    },
    "refined_idea": {
      "type": "string",
      "maxLength": 4000
    },
    "shipped_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp recorded when /forge:ship completes the ship phase. Required for post-merge /forge:qa to find the feature; absence means ship has not completed."
    }
  },
  "allOf": [
    {
      "$comment": "Tier-allowed phase set for focused. Focused tier ends at verify; QA only exists on standard and full per the QA-lifecycle policy decided in the state-machine pre-flight.",
      "if": {
        "required": ["tier"],
        "properties": { "tier": { "const": "focused" } }
      },
      "then": {
        "properties": {
          "phases": {
            "propertyNames": {
              "enum": ["spec", "execute", "verify"]
            }
          }
        }
      }
    },
    {
      "$comment": "Tier-allowed phase set for standard. The optional research slot is admitted because /forge:do with --research prepends it to the canonical 8-phase standard list (routing.phase_list opt-in); features that do not opt in simply never instantiate the research block.",
      "if": {
        "required": ["tier"],
        "properties": { "tier": { "const": "standard" } }
      },
      "then": {
        "properties": {
          "phases": {
            "propertyNames": {
              "enum": [
                "research",
                "spec",
                "scenarios",
                "plan",
                "crucible",
                "review",
                "execute",
                "verify",
                "ship",
                "qa"
              ]
            }
          }
        }
      }
    },
    {
      "$comment": "Tier-allowed phase set for full. Full tier always carries refine + research + domain in addition to the standard set, plus qa post-ship.",
      "if": {
        "required": ["tier"],
        "properties": { "tier": { "const": "full" } }
      },
      "then": {
        "properties": {
          "phases": {
            "propertyNames": {
              "enum": [
                "refine",
                "research",
                "spec",
                "domain",
                "scenarios",
                "plan",
                "crucible",
                "review",
                "execute",
                "verify",
                "ship",
                "qa"
              ]
            }
          }
        }
      }
    }
  ]
}
