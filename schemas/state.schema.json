{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idd.dev/schemas/state.schema.json",
  "title": "IDD Per-Feature State",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature_id", "tier", "current_phase", "phases", "skipped", "deviations", "commits"],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$",
      "description": "YYYY-MM-DD-slug identifier."
    },
    "tier": {
      "type": "string",
      "enum": ["focused", "standard", "full"]
    },
    "current_phase": {
      "type": "string",
      "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship", "done"]
    },
    "phases": {
      "type": "object",
      "propertyNames": {
        "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship"]
      },
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "skipped"]
          },
          "started_at":   { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "current_slice": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "reason"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "cause", "resolution"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship"]
          },
          "cause":      { "type": "string" },
          "resolution": { "type": "string" },
          "logged_at":  { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sha", "phase", "subject"],
        "properties": {
          "sha":     { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
          "phase": {
            "type": "string",
            "enum": ["refine", "research", "spec", "domain", "scenarios", "plan", "crucible", "review", "execute", "verify", "ship"]
          },
          "subject": { "type": "string", "minLength": 1 },
          "logged_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  }
}
