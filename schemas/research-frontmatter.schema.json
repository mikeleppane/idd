{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/research-frontmatter.schema.json",
  "type": "object",
  "required": ["spec", "status", "tier", "research_grounding"],
  "additionalProperties": false,
  "properties": {
    "spec": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])-[a-z0-9](?:[a-z0-9]|-(?=[a-z0-9]))+$"
    },
    "status": {"type": "string", "enum": ["in_progress", "done", "skipped"]},
    "tier": {"type": "string", "enum": ["focused", "standard", "full"]},
    "parallel_used": {"type": "boolean", "default": false},
    "research_grounding": {"type": "string", "enum": ["full", "degraded", "websearch", "byod", "byod-partial"]}
  }
}
