{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/research-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "ecosystem_name": {
      "type": "string",
      "enum": ["python", "node", "rust", "go", "ruby", "java", "dotnet", "elixir", "php", "swift", "dart", "generic"]
    }
  },
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1, "default": 1},
    "websearch_fallback": {"type": "boolean", "default": false},
    "websearch_max_queries_per_run": {"type": "integer", "minimum": 1, "maximum": 20, "default": 5},
    "websearch_per_query_max_results": {"type": "integer", "minimum": 1, "maximum": 10, "default": 3},
    "byod_stale_days": {"type": "integer", "minimum": 1, "maximum": 3650, "default": 90},
    "ecosystems": {
      "type": "array",
      "items": {"$ref": "#/$defs/ecosystem_name"},
      "uniqueItems": true,
      "description": "User pin: limit ecosystem detector to listed plugins. When absent, detector runs all available plugins."
    },
    "ecosystem_overrides": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/ecosystem_name"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "manifest_paths": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
