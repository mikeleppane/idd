{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/review-frontmatter.schema.json",
  "title": "FORGE REVIEW.md frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "target", "status", "cycles"],
  "properties": {
    "spec": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"
    },
    "target": {
      "type": "string",
      "enum": ["plan", "code"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "resolved"]
    },
    "cycles": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    }
  }
}
