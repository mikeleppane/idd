{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/delta-proposal-frontmatter.schema.json",
  "title": "FORGE Delta Proposal Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "affects_capability", "status", "created"],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$" },
    "affects_capability": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,}$" },
    "status": { "type": "string", "enum": ["draft", "approved", "merged"] },
    "created": { "type": "string", "format": "date" }
  }
}
