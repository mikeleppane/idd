{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/git-conventions-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1, "default": 1},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_length": {"type": "integer", "minimum": 10, "maximum": 200},
        "require_conventional_commits": {"type": "boolean"},
        "allowed_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Allowed scope token. Must start with a lowercase letter and contain only lowercase letters, digits, and hyphens. Underscores are NOT allowed — use hyphens (e.g. 'phase-1' not 'phase_1') for consistency with the Conventional Commits canonical examples."
          },
          "uniqueItems": true
        }
      }
    },
    "trailers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ban_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      }
    }
  }
}
